{
  "name": "utm2023-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --output-path dist",
    "build:dev": "ng build --output-path dist --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:android": "cd cordova; cordova platform rm android; cordova platform add android; ng build --output-path cordova/www; cordova build android --release",
    "build:ios": "cd cordova; ng build --output-path cordova/www; cordova build ios",
    "run:android": "cd cordova; ng build --output-path cordova/www; cordova run android",
    "run:ios": "cd cordova; ng build --output-path cordova/www; cordova run ios",
    "emulate:android": "cd cordova; cordova emulate android",
    "emulate:ios": "cd cordova; cordova emulate ios",
    "dev:ssr": "ng run utm2023-frontend:serve-ssr",
    "serve:ssr": "node dist/utm2023-frontend/server/main.js",
    "build:ssr": "ng build && ng run utm2023-frontend:server",
    "prerender": "ng run utm2023-frontend:prerender"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^15.2.0",
    "@angular/cdk": "^15.2.9",
    "@angular/common": "^15.2.0",
    "@angular/compiler": "^15.2.0",
    "@angular/core": "^15.2.0",
    "@angular/forms": "^15.2.0",
    "@angular/material": "^15.2.9",
    "@angular/platform-browser": "^15.2.0",
    "@angular/platform-browser-dynamic": "^15.2.0",
    "@angular/platform-server": "^15.2.0",
    "@angular/router": "^15.2.0",
    "@nguniversal/express-engine": "^15.2.1",
    "@ngx-matomo/router": "^4.1.0",
    "@ngx-matomo/tracker": "^4.1.0",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "@photo-sphere-viewer/core": "^5.8.2",
    "@photo-sphere-viewer/equirectangular-video-adapter": "^5.9.0",
    "@photo-sphere-viewer/video-plugin": "^5.9.0",
    "@turf/turf": "^6.5.0",
    "@types/howler": "^2.2.7",
    "express": "^4.15.2",
    "howler": "^2.2.3",
    "mapbox-gl": "^2.14.1",
    "rxjs": "~7.8.0",
    "three": "^0.166.1",
    "tslib": "^2.3.0",
    "viewerjs": "^1.11.5",
    "zone.js": "~0.12.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^15.2.6",
    "@angular/cli": "~15.2.6",
    "@angular/compiler-cli": "^15.2.0",
    "@nguniversal/builders": "^15.2.1",
    "@types/express": "^4.17.0",
    "@types/jasmine": "~4.3.0",
    "@types/mapbox-gl": "^2.7.10",
    "@types/node": "^14.15.0",
    "@types/three": "^0.166.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "prettier": "^2.8.8",
    "typescript": "~4.9.4"
  }
}