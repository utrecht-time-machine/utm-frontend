{
  "name": "utm2023-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --output-path dist",
    "build:dev": "ng build --output-path dist --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:android": "cd cordova; cordova platform rm android; cordova platform add android; ng build --output-path cordova/www; cordova build android --release",
    "build:ios": "cd cordova; cordova platform rm ios; cordova platform add ios; ng build --output-path cordova/www; cordova build ios",
    "run:android": "cd cordova; ng build --output-path cordova/www; cordova run android",
    "run:ios": "cd cordova; ng build --output-path cordova/www; cordova run ios",
    "emulate:android": "cd cordova; cordova emulate android",
    "emulate:ios": "cd cordova; cordova emulate ios",
    "e2e": "ng e2e --configuration=production",
    "cypress:run:live-prod": "CYPRESS_BASE_URL=https://utrechttimemachine.nl cypress run",
    "cypress:run:local-prod": "start-server-and-test 'ng serve --configuration=production' http://localhost:4200 'cypress run'",
    "serve:ssr:utm2023-frontend": "node dist/utm2023-frontend/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/platform-server": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@angular/ssr": "^18.2.21",
    "@mui/icons-material": "^6.1.1",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "@photo-sphere-viewer/core": "^5.8.2",
    "@photo-sphere-viewer/equirectangular-video-adapter": "^5.9.0",
    "@photo-sphere-viewer/video-plugin": "^5.9.0",
    "@turf/turf": "^6.5.0",
    "@types/howler": "^2.2.7",
    "cordova-background-geolocation-lt": "^4.18.0",
    "express": "^4.18.2",
    "howler": "^2.2.3",
    "mapbox-gl": "^2.14.1",
    "ngx-matomo-client": "^6.4.1",
    "rxjs": "~7.8.0",
    "three": "^0.166.1",
    "tslib": "^2.3.0",
    "viewerjs": "^1.11.5",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "~18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@cypress/schematic": "^2.5.2",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~4.3.0",
    "@types/mapbox-gl": "^2.7.10",
    "@types/node": "^14.15.0",
    "@types/three": "^0.166.0",
    "browser-sync": "^3.0.0",
    "cypress": "latest",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "prettier": "^2.8.8",
    "start-server-and-test": "^2.0.12",
    "typescript": "~5.4.5"
  }
}
