<?xml version='1.0' encoding='utf-8'?>
<widget id="nl.utrechttimemachine" version="1.0.0" xmlns="http://www.w3.org/ns/widgets">
  <name>Utrecht Time Machine</name>
  <description>Utrecht Time Machine</description>
  <author email="info@utrechttimemachine.nl" href="https://utrechttimemachine.nl">
    Utrecht Time Machine Team
  </author>
  <content src="index.html"/>
  <allow-intent href="http://*/*"/>
  <allow-intent href="https://*/*"/>

  <icon src="res/logo/logo.png"/>

  <platform name="android">
    <preference name="AndroidWindowSplashScreenBackground" value="#fe003e"/>
    <allow-intent href="market:*"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>

    <!--
        mdpi    : 48x48 px
        hdpi    : 72x72 px
        xhdpi   : 96x96 px
        xxhdpi  : 144x144 px
        xxxhdpi : 192x192 px
    -->
    <icon src="res/icon/android/ldpi.png" density="ldpi" />
    <icon src="res/icon/android/mdpi.png" density="mdpi" />
    <icon src="res/icon/android/hdpi.png" density="hdpi" />
    <icon src="res/icon/android/xhdpi.png" density="xhdpi" />
    <icon src="res/icon/android/xxhdpi.png" density="xxhdpi" />
    <icon src="res/icon/android/xxxhdpi.png" density="xxxhdpi" />
  </platform>

  <platform name="ios">
    <icon src="res/icon/ios/icon-20.png" width="20" height="20"/>
    <icon src="res/icon/ios/icon-20@2x.png" width="40" height="40"/>
    <icon src="res/icon/ios/icon-20@3x.png" width="60" height="60"/>
    <icon src="res/icon/ios/icon-24@2x.png" width="48" height="48"/>
    <icon src="res/icon/ios/icon-27.5@2x.png" width="55" height="55"/>
    <icon src="res/icon/ios/icon-29.png" width="29" height="29"/>
    <icon src="res/icon/ios/icon-29@2x.png" width="58" height="58"/>
    <icon src="res/icon/ios/icon-29@3x.png" width="87" height="87"/>
    <icon src="res/icon/ios/icon-40.png" width="40" height="40"/>
    <icon src="res/icon/ios/icon-40@2x.png" width="80" height="80"/>
    <icon src="res/icon/ios/icon-44@2x.png" width="88" height="88"/>
    <icon src="res/icon/ios/icon-50.png" width="50" height="50"/>
    <icon src="res/icon/ios/icon-50@2x.png" width="100" height="100"/>
    <icon src="res/icon/ios/icon-60.png" width="60" height="60"/>
    <icon src="res/icon/ios/icon-60@2x.png" width="120" height="120"/>
    <icon src="res/icon/ios/icon-60@3x.png" width="180" height="180"/>
    <icon src="res/icon/ios/icon-72.png" width="72" height="72"/>
    <icon src="res/icon/ios/icon-72@2x.png" width="144" height="144"/>
    <icon src="res/icon/ios/icon-76.png" width="76" height="76"/>
    <icon src="res/icon/ios/icon-76@2x.png" width="152" height="152"/>
    <icon src="res/icon/ios/icon-83.5@2x.png" width="167" height="167"/>
    <icon src="res/icon/ios/icon-86@2x.png" width="172" height="172"/>
    <icon src="res/icon/ios/icon-98@2x.png" width="196" height="196"/>
    <icon src="res/icon/ios/icon-1024.png" width="1024" height="1024"/>
    <icon src="res/icon/ios/icon.png" width="57" height="57"/>
    <icon src="res/icon/ios/icon@2x.png" width="114" height="114"/>

    <preference name="scheme" value="app"/>
    <preference name="hostname" value="localhost"/>
    <!--    NSLocationAlwaysAndWhenInUseUsageDescription-->
    <config-file platform="ios" target="*-Info.plist" parent="NSLocationAlwaysAndWhenInUseUsageDescription">
      <string>Utrecht Time Machine toont historische informatie over je huidige locatie. Je locatie wordt alleen door de
        app zelf gebruikt en wordt met niemand gedeeld.
      </string>
    </config-file>
  </platform>

  <preference name="FadeSplashScreen" value="true"/>
</widget>
